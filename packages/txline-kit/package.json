{
  "name": "@0xpulseplay/txline-kit",
  "version": "0.1.0",
  "description": "Safe TypeScript, replay, and Solana CPI tooling for TxLINE",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xPulsePlay/txline-kit.git",
    "directory": "packages/txline-kit"
  },
  "homepage": "https://txline-kit.claude.do",
  "bugs": "https://github.com/0xPulsePlay/txline-kit/issues",
  "keywords": ["solana", "sports-data", "oracle", "replay", "merkle-proof"],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "txline-replay": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.js",
      "require": "./dist/auth.cjs"
    },
    "./data": {
      "types": "./dist/data.d.ts",
      "import": "./dist/data.js",
      "require": "./dist/data.cjs"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "require": "./dist/errors.cjs"
    },
    "./replay": {
      "types": "./dist/replay.d.ts",
      "import": "./dist/replay.js",
      "require": "./dist/replay.cjs"
    },
    "./proofs": {
      "types": "./dist/proofs.d.ts",
      "import": "./dist/proofs.js",
      "require": "./dist/proofs.cjs"
    },
    "./onchain": {
      "types": "./dist/onchain.d.ts",
      "import": "./dist/onchain.js",
      "require": "./dist/onchain.cjs"
    },
    "./merkle": {
      "types": "./dist/merkle.d.ts",
      "import": "./dist/merkle.js",
      "require": "./dist/merkle.cjs"
    },
    "./journal": {
      "types": "./dist/journal.d.ts",
      "import": "./dist/journal.js",
      "require": "./dist/journal.cjs"
    },
    "./strategy": {
      "types": "./dist/strategy.d.ts",
      "import": "./dist/strategy.js",
      "require": "./dist/strategy.cjs"
    },
    "./keeper": {
      "types": "./dist/keeper.d.ts",
      "import": "./dist/keeper.js",
      "require": "./dist/keeper.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "scripts": {
    "build": "tsup --config ../../tsup.config.ts",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@coral-xyz/anchor": "0.32.1",
    "@solana/web3.js": "1.98.4",
    "@types/bn.js": "^5.1.6",
    "bn.js": "5.2.5",
    "tweetnacl": "1.0.3",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@solana/spl-token": "0.4.15",
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
