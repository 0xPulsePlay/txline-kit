{
  "name": "txline-kit-workspace",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm --filter @0xpulseplay/txline-kit build && pnpm --filter @0xpulseplay/txline-learn build",
    "check": "pnpm typecheck && pnpm test",
    "typecheck": "pnpm --filter @0xpulseplay/txline-kit typecheck && pnpm --filter @0xpulseplay/txline-learn typecheck",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:rust": "cargo test --workspace",
    "check:rust": "cargo fmt --all -- --check && cargo clippy --workspace --all-targets -- -D warnings && cargo check -p txline-kit-cpi --no-default-features --features devnet",
    "program:build": "cargo build-sbf --manifest-path programs/txline-demo-escrow/Cargo.toml --sbf-out-dir target/deploy",
    "program:idl": "anchor idl build -o target/txline_demo_escrow.json --program-name txline_demo_escrow --no-docs",
    "proof:report": "node scripts/proof-report.mjs",
    "fixture:synthetic": "node scripts/create-synthetic-fixture.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
